rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ===== Profile Photos =====
    // ผู้ใช้อัปโหลดและอ่านรูปตัวเองได้ / คนอื่นอ่านได้อย่างเดียว
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // max 5MB
        && request.resource.contentType.matches('image/.*');
    }
    
    // ===== Documents (ใบประกอบวิชาชีพ, บัตรประชาชน) =====
    // เจ้าของเท่านั้นที่อัปโหลดและอ่านได้ (admin ใช้ Admin SDK ผ่าน Cloud Functions)
    match /users/{userId}/documents/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
      allow create, update: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024; // max 10MB
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }
    
    // ===== Chat Attachments =====
    // เฉพาะผู้ที่เป็น participant ของ conversation นั้นเท่านั้น
    match /chat/{conversationId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants;
      allow write: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants
        && request.resource.size < 10 * 1024 * 1024; // max 10MB
    }

    match /chats/{conversationId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants;
      allow write: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants
        && request.resource.size < 10 * 1024 * 1024; // max 10MB
    }
    
    // ===== Job Images =====
    match /jobs/{jobId}/{fileName} {
      allow read: if true; // งานเปิดให้ทุกคนดู
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // ===== ปฏิเสธทุกอย่างอื่น =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
