{
  "expo": {
    "name": "NurseGo",
    "slug": "nurse-job-app",
    "version": "1.0.0",
    "scheme": "nursego",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90D9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nursego.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "ใช้กล้องเพื่ออัปโหลดรูปโปรไฟล์และเอกสาร",
        "NSPhotoLibraryUsageDescription": "ใช้คลังรูปเพื่ออัปโหลดรูปโปรไฟล์และเอกสาร",
        "NSPhotoLibraryAddUsageDescription": "บันทึกรูปไว้ในคลัง",
        "NSLocationWhenInUseUsageDescription": "ใช้ตำแหน่งเพื่อหางานใกล้บ้านคุณ",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ใช้ตำแหน่งเพื่อแจ้งเตือนงานใกล้บ้านแม้แอปทำงานอยู่เบื้องหลัง",
        "UIBackgroundModes": ["remote-notification", "fetch"],
        "NSFaceIDUsageDescription": "ใช้ Face ID เพื่อเข้าสู่ระบบ"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A90D9"
      },
      "package": "com.nursego.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "@sentry/react-native",
        {
          "organization": "nursego",
          "project": "nursego-app"
        }
      ]
    ],
    "extra": {
      "longdoApiKey": "42cbc4a02c0bc712bafa5e0b44ae2cd7",
      "eas": {
        "projectId": "ab76f7f0-0e2f-4976-83ab-a7204452425f"
      }
    }
  }
}
