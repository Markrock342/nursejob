rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    // ==========================================
    // USERS
    // ==========================================
    match /users/{userId} {
      // Read: owner, admin, or any signed-in user (public profile — no sensitive fields at root)
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.role in ['nurse', 'hospital', 'user']
        && request.resource.data.get('isAdmin', false) == false;
      allow update: if isAdmin() || (
        isOwner(userId)
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(['role', 'isAdmin'])
      );
      allow delete: if isAdmin();

      // Sensitive sub-data — owner only
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ==========================================
    // JOBS / SHIFTS
    // ==========================================
    match /shifts/{jobId} {
      // Public job board — anyone can browse without login
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.posterId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.status in ['active', 'urgent']
        && request.resource.data.shiftRate is number
        && request.resource.data.shiftRate >= 0;

      allow update: if (
        // Owner/admin can update their own posts as before
        isSignedIn() && (
          resource.data.posterId == request.auth.uid || isAdmin()
        )
      ) || (
        // Public-safe view counter: allow only +1 on viewsCount and nothing else
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['viewsCount'])
        && request.resource.data.get('viewsCount', 0) == resource.data.get('viewsCount', 0) + 1
      );

      allow delete: if isSignedIn() && (
        resource.data.posterId == request.auth.uid || isAdmin()
      );
    }

    // ==========================================
    // SHIFT CONTACTS (Applications)
    // ==========================================
    match /shift_contacts/{contactId} {
      allow read: if isSignedIn() && (
        resource.data.interestedUserId == request.auth.uid ||
        resource.data.posterId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.interestedUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.interestedUserId == request.auth.uid ||
        resource.data.posterId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.interestedUserId == request.auth.uid ||
        resource.data.posterId == request.auth.uid ||
        isAdmin()
      );
    }

    // ==========================================
    // CONVERSATIONS
    // ==========================================
    match /conversations/{conversationId} {
      allow read: if isSignedIn() &&
        (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          || isAdmin()
        );
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() &&
          resource.data.senderId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // ==========================================
    // FAVORITES
    // ==========================================
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ==========================================
    // NOTIFICATIONS
    // ==========================================
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only notify yourself or admin (Cloud Functions bypass rules via Admin SDK)
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ==========================================
    // REVIEWS
    // ==========================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isSignedIn() && resource.data.reviewerId == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.reviewerId == request.auth.uid || isAdmin()
      );
    }

    // ==========================================
    // DOCUMENTS
    // ==========================================
    match /documents/{documentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ==========================================
    // VERIFICATIONS
    // ==========================================
    match /verifications/{verificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // REPORTS
    // ==========================================
    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.reporterId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // SUBSCRIPTION PLANS (userPlans)
    // ==========================================
    match /userPlans/{planId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // PURCHASES
    // ==========================================
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // IAP RECEIPTS — Cloud Functions only
    // ==========================================
    match /iap_receipts/{receiptId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ==========================================
    // FEEDBACK
    // ==========================================
    match /feedback/{feedbackId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // HOSPITALS (Public reference data)
    // ==========================================
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // REFERRALS
    // ==========================================
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        resource.data.referrerUid == request.auth.uid ||
        resource.data.refereeUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.refereeUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // OTP CODES — Cloud Function Admin SDK only
    // No client read/write allowed
    // ==========================================
    match /otpCodes/{phone} {
      allow read, write: if false;
    }

    match /otpRateLimit/{phone} {
      allow read, write: if false;
    }

  }
}