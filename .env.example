# ============================================
# NurseGo - Environment Variables
# ============================================
# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# cp .env.example .env

# --- Firebase (หา values ได้ที่ Firebase Console → Project Settings) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Maps ---
EXPO_PUBLIC_LONGDO_API_KEY=your_longdo_api_key_here
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_key_here

# --- Admin (SHA-256 hashed password) ---
# สร้าง hash: node scripts/generateAdminHash.js YOUR_PASSWORD
EXPO_PUBLIC_ADMIN_USERNAME=admin
EXPO_PUBLIC_ADMIN_PASSWORD_HASH=

# --- Feature Flags ---
# true = แสดง mock data (dev เท่านั้น), false = production
EXPO_PUBLIC_SHOW_MOCK_DATA=false
